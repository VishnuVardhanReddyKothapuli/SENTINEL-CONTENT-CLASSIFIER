# ============================================================
# NSFWGuard - Environment Variables
# Copy this to .env and fill in your real values.
# NEVER commit the real .env to git.
# ============================================================

# ── App ────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# ── MySQL Database ─────────────────────────────────────────
MYSQL_USER=nsfw_user
MYSQL_PASSWORD=your_db_password_here
MYSQL_HOST=db               # use "localhost" if not using Docker
MYSQL_PORT=3306
MYSQL_DB=nsfw_classifier

# ── Google OAuth ────────────────────────────────────────────
# Get these from https://console.cloud.google.com/
# 1. Create a project
# 2. Go to APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Add http://localhost:8000/auth/google/callback as an authorized redirect URI
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
